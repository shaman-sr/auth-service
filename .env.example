# Copy to .env for local development: cp .env.example .env
APP_NAME=auth-service

POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
POSTGRES_DB=auth
# Use "localhost" for `just dev`; docker-compose overrides this to "db".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT — generate a strong random secret for real environments, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-secret-change-me-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
